[project]
title = defold-random
version = 1.2.5

[bootstrap]
main_collection = /example/main.collectionc

[input]
game_binding = /input/game.input_bindingc
use_accelerometer = 0
gamepads = /builtins/input/default.gamepadsc

[ios]
bundle_identifier = com.example.todo

[osx]
bundle_identifier = com.example.todo

[android]
input_method = HiddenInputField

[script]
shared_state = 1

[library]
include_dirs = pcgrandom
